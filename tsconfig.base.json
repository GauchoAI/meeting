{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@meeting/protocol": ["packages/protocol/src/index.ts"],
      "@meeting/transcript": ["packages/transcript/src/index.ts"]
    }
  }
}

