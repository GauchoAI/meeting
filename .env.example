# Optional secrets/private overrides only.
# Normal local-first defaults live in committed config/meeting.local.json.
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
MEETING_REALTIME_MODEL=gpt-realtime-2
MEETING_REALTIME_VOICE=marin

# Optional public GitHub Pages lobby / Firebase Realtime Database registry.
# Uses a namespaced path so it does not dirty the database root.
VITE_FIREBASE_DATABASE_URL=https://signaling-dcfad-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_NAMESPACE=gauchoai-meeting

# Local speech selector. Committed defaults live in config/meeting.local.json:
# live = Parakeet STT + MLX Voxtral TTS, narration = Parakeet STT + Qwen3 TTS.
# Override these only when testing a different mode/provider.
# MEETING_SPEECH_MODE=live
# MEETING_LIVE_STT_PROVIDER=parakeet-http
# MEETING_LIVE_TTS_PROVIDER=mlx-voxtral
# MEETING_NARRATION_STT_PROVIDER=parakeet-http
# MEETING_NARRATION_TTS_PROVIDER=qwen3-tts
# MEETING_EXPERIMENTAL_STT_PROVIDER=moshi-http
# MEETING_EXPERIMENTAL_TTS_PROVIDER=qwen3-tts
# STT_PROVIDER=parakeet-http
# MEETING_TTS_PROVIDER=mlx-voxtral

# Local speech experiments:
# STT_PROVIDER=local-whisper
# STT_PROVIDER=voxtral-http
# VOXTRAL_STT_URL=http://localhost:8787/transcribe
# STT_PROVIDER=moshi-http
# MOSHI_STT_URL=http://localhost:8788/transcribe
# STT_PROVIDER=parakeet-http
# PARAKEET_STT_URL=http://localhost:8793/transcribe
# PARAKEET_STT_MODEL_PATH=/Users/you/Library/Application Support/com.pais.handy/models/parakeet-tdt-0.6b-v3-int8

# Local/API speech output. Browser speechSynthesis is intentionally not used.
# MEETING_TTS_PROVIDER=chatterbox-turbo
# CHATTERBOX_TTS_URL=http://127.0.0.1:8791/synthesize
#
# Hosted Mistral Voxtral TTS. Requires a Mistral key unless MISTRAL_TTS_BASE_URL
# points at a local OpenAI-compatible/Mistral-compatible server.
# MEETING_TTS_PROVIDER=mistral-voxtral
# MISTRAL_API_KEY=
# MISTRAL_TTS_MODEL=voxtral-mini-tts-2603
# MISTRAL_TTS_RESPONSE_FORMAT=wav
# MISTRAL_TTS_PCM_SAMPLE_RATE=24000
# MISTRAL_TTS_VOICE_ID=
# MISTRAL_TTS_REF_AUDIO_PATH=
#
# Local Mistral Voxtral TTS through MLX Audio on Apple Silicon.
# Start with: scripts/start-voxtral-mlx-tts.sh
# MEETING_TTS_PROVIDER=mlx-voxtral
# VOXTRAL_MLX_TTS_URL=http://127.0.0.1:8792/v1/audio/speech
# VOXTRAL_MLX_TTS_MODEL=mlx-community/Voxtral-4B-TTS-2603-mlx-4bit
# VOXTRAL_MLX_TTS_VOICE=casual_male
# VOXTRAL_MLX_TTS_AUTO_VOICE=true
# VOXTRAL_MLX_TTS_SPANISH_VOICE=es_male
# VOXTRAL_MLX_TTS_RESPONSE_FORMAT=wav
# VOXTRAL_MLX_TTS_STREAMING_INTERVAL=0.32
#
# Local Qwen3 TTS voice-clone experiment. Supports English, Spanish, and Russian
# with macOS-generated reference voices by default.
# Start with: scripts/start-qwen3-tts.sh
# MEETING_TTS_PROVIDER=qwen3-tts
# QWEN3_TTS_URL=http://127.0.0.1:8794/synthesize
# QWEN3_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-Base
# QWEN3_TTS_DEVICE=auto
# QWEN3_TTS_DTYPE=auto
# QWEN3_TTS_MAX_NEW_TOKENS=900
# QWEN3_TTS_DO_SAMPLE=false
# QWEN3_TTS_TEMPERATURE=0.6
# QWEN3_TTS_TOP_P=0.9
# QWEN3_TTS_WORKERS=2
